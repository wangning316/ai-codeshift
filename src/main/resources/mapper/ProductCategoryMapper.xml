<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.project.mapper.ProductCategoryMapper">

    <!-- 根据分类名称、开启状态、父分类编号、父分类编号数组有值的组合参数从数据库查询商品分类列表 -->
    <select id="selectByCondition" resultType="com.company.project.entity.po.ProductCategoryPO">
        SELECT * FROM product_category
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="parentIds != null and parentIds.size() > 0">
                AND parent_id IN
                <foreach collection="parentIds" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            AND deleted = 0
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <!-- 根据父分类编号从数据库查询商品分类 -->
    <select id="selectByParentId" resultType="com.company.project.entity.po.ProductCategoryPO">
        SELECT * FROM product_category
        <where>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            AND deleted = 0
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <!-- 根据分类名称和父分类编号查询商品分类 -->
    <select id="selectByNameAndParentId" resultType="com.company.project.entity.po.ProductCategoryPO">
        SELECT * FROM product_category
        <where>
            <if test="name != null and name != ''">
                AND name = #{name}
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            AND deleted = 0
        </where>
    </select>

</mapper>